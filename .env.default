PROJECT_NAME=mediamtxui
MEDIAMTX_VERSION=latest-ffmpeg
DEBUG=0
VERBOSE=1

SERVER_PORT=3000

RTSP_HOST=mediamtx
RTSP_PORT=8554
RTMP_PORT=1935
HLS_PORT=8888
WEBRTC_PORT=8889
WEBRTC_UDP_PORT=8189
API_PORT=9997
METRICS_PORT=9998

# Caddy reverse proxy
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
DOMAIN=localhost

# Hardware acceleration (vaapi, qsv, cuda, none)
HW_ACCEL=none

# Recording storage
RECORDING_PATH=./recordings

# Desktop app wrapper (electron, tauri, none)
DESKTOP_WRAPPER=none
